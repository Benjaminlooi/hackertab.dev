# Required — Upstash Redis (via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Optional — Reddit OAuth (register at https://www.reddit.com/prefs/apps as script-type app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional — Product Hunt OAuth (register at https://www.producthunt.com/v2/oauth/applications)
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=

# Optional — IndieHackers Algolia search (public read-only API key)
INDIEHACKERS_ALGOLIA_KEY=

# Runtime (Vercel sets this automatically in production)
NODE_ENV=development
